{
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.jdt.ls.java.home": "C:\\Program Files\\Java\\jdk-21.0.10",
  "gradle.wrapper.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  
  /* MATCH GRADLE TO SYSTEM */
  "gradle.java.home": "C:\\Program Files\\Android\\Android Studio\\jbr",
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-21",
      "path": "C:\\Program Files\\Java\\jdk-21.0.10",
      "default": true
    }
  ],

  /* FLUTTER & DART SPEED */
  "dart.flutterSdkPath": "E:\\flutter",
  "dart.sdkPath": "E:\\flutter",
  "dart.analysisExcludedFolders": [
    "windows",
    "linux",
    "macos",
    "build"
  ],
  "dart.previewLsp": true,
  "dart.hotReloadOnSave": "all",

  /* TERMINAL & PERFORMANCE */
  "terminal.integrated.gpuAcceleration": "on",
  "java.gradle.buildServer.enabled": "off",
  "gradle.allowParallelRun": true, // Changed to true: your Ryzen 2400G has 8 threads!
  
  /* CLEANUP */
  "php.validate.enable": false,
  "cmake.ignoreCMakeListsMissing": true,
  "markdownlint.enable": false,
  "files.associations": {
    "tuple": "cpp",
    "utility": "cpp",
    "xstring": "cpp",
    "ios": "cpp"
  }
}